{
  "name": "minio-parquet-sink",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "topics": "fullfillment.TYROK",
    "store.url": "http://minio:9000",
    "aws.access.key.id": "admin",
    "aws.secret.access.key": "password123",
    "s3.bucket.name": "client-bucket",
    "s3.region": "us-east-1",
    "s3.part.size": "5242880",

    "tasks.max": "2", 
    "connection.timeout.ms": "30000",
    "read.timeout.ms": "30000",
    "retry.backoff.ms": "5000",
    "max.retries": "10",

    "batch.size": "2000",
    "linger.ms": "1000",
    "max.buffered.records": "10000",
    "flush.timeout.ms": "10000",
    "flush.size": "5000",
    "rotate.interval.ms": "600000",

    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq.e-sink.client",
    "errors.deadletterqueue.topic.replication.factor": "1",
    "errors.deadletterqueue.context.headers.enable": "true",

    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
    "parquet.codec": "snappy",
    
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "schema.compatibility": "BACKWARD",
    
    "drop.invalid.char": "true",
    "key.ignore": "true",
    "schema.ignore": "true",
    "type.name": "",
    "behavior.on.null.values": "ignore",

    "write.method": "upsert",
    "upsert.delete.enabled": "true",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "partitioner.class": "io.confluent.connect.storage.partitioner.DefaultPartitioner",
    "path.format": "'year'=YYYY/'month'=MM/'day'=dd/'hour'=HH",
    "locale": "en-US",
    "timezone": "UTC",    
    "partition.duration.ms": "86400000"
  }
}
