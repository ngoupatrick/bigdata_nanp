FROM python:3.11-slim

# Évite la création de fichiers .pyc et active l'affichage en temps réel
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Copier d'abord uniquement le fichier de dépendances
#COPY ./python/faust/requirements.txt /app/

# Copie de vos fichiers locaux dans le conteneur
# requirements.txt se trouve dans ./python/faust/requirements.txt, donc on doit copier le dossier faust entier pour l'avoir
COPY ./python/faust /app/

# Installation des dépendances sans cache
RUN pip install --no-cache-dir -r requirements.txt